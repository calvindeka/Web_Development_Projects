<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories | Cocktail Finder</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="logo">
                <span class="logo-icon">🍹</span>
                <span class="logo-text">Cocktail Finder</span>
            </a>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/categories" class="active">Categories</a></li>
                <li><a href="/random">Random</a></li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content page-content">
        <div class="page-header">
            <h1>Browse by Category</h1>
            <p>Explore cocktails organized by their type</p>
        </div>

        <% if (error) { %>
            <!-- Error Message -->
            <div class="error-message">
                <p><%= error %></p>
                <a href="/" class="btn btn-primary">Back to Home</a>
            </div>
        <% } else if (categories && categories.length > 0) { %>
            <!-- Categories Grid -->
            <div class="categories-grid">
                <% categories.forEach(cat => { %>
                    <a href="/category/<%= encodeURIComponent(cat.strCategory) %>" class="category-card">
                        <div class="category-icon">
                            <% 
                                // Assign icons based on category
                                const icons = {
                                    'Ordinary Drink': '🥃',
                                    'Cocktail': '🍸',
                                    'Shake': '🥤',
                                    'Shot': '🔫',
                                    'Coffee / Tea': '☕',
                                    'Cocoa': '🍫',
                                    'Beer': '🍺',
                                    'Soft Drink': '🥤',
                                    'Punch / Party Drink': '🎉',
                                    'Homemade Liqueur': '🍾',
                                    'Other / Unknown': '❓'
                                };
                                const icon = icons[cat.strCategory] || '🍹';
                            %>
                            <%= icon %>
                        </div>
                        <h3><%= cat.strCategory %></h3>
                    </a>
                <% }) %>
            </div>
        <% } %>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <p>Powered by <a href="https://www.thecocktaildb.com/" target="_blank" rel="noopener">TheCocktailDB API</a></p>
            <p class="footer-note">Built by Calvin Deka | API Capstone Project</p>
        </div>
    </footer>
</body>
</html>
