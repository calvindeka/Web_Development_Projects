<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Edit your article on Faithful Word.">
    <title>Edit Article | Faithful Word</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <main>
        <section class="form-section">
            <div class="container container-narrow">
                <header class="form-header">
                    <h1>Edit Article</h1>
                    <p>Make changes to your reflection or teaching.</p>
                </header>

                <form action="/posts/<%= post.id %>?_method=PUT" method="POST" class="post-form">
                    <div class="form-group">
                        <label for="title">Title</label>
                        <input 
                            type="text" 
                            id="title" 
                            name="title" 
                            required 
                            value="<%= post.title %>"
                            maxlength="200"
                        >
                    </div>

                    <div class="form-group">
                        <label for="author">Author</label>
                        <input 
                            type="text" 
                            id="author" 
                            name="author" 
                            required 
                            value="<%= post.author %>"
                            maxlength="100"
                        >
                    </div>

                    <div class="form-group">
                        <label for="category">Category</label>
                        <select id="category" name="category" required>
                            <option value="">Select a category</option>
                            <option value="Devotional" <%= post.category === 'Devotional' ? 'selected' : '' %>>Devotional</option>
                            <option value="Scripture Study" <%= post.category === 'Scripture Study' ? 'selected' : '' %>>Scripture Study</option>
                            <option value="Prayer" <%= post.category === 'Prayer' ? 'selected' : '' %>>Prayer</option>
                            <option value="Testimony" <%= post.category === 'Testimony' ? 'selected' : '' %>>Testimony</option>
                            <option value="Christian Living" <%= post.category === 'Christian Living' ? 'selected' : '' %>>Christian Living</option>
                            <option value="Faith" <%= post.category === 'Faith' ? 'selected' : '' %>>Faith</option>
                            <option value="Grace" <%= post.category === 'Grace' ? 'selected' : '' %>>Grace</option>
                            <option value="Community" <%= post.category === 'Community' ? 'selected' : '' %>>Community</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="excerpt">Excerpt</label>
                        <textarea 
                            id="excerpt" 
                            name="excerpt" 
                            rows="3" 
                            required
                            maxlength="300"
                        ><%= post.excerpt %></textarea>
                        <span class="form-hint">This will be displayed as a preview on the homepage.</span>
                    </div>

                    <div class="form-group">
                        <label for="content">Content</label>
                        <textarea 
                            id="content" 
                            name="content" 
                            rows="15" 
                            required
                        ><%= post.content %></textarea>
                        <span class="form-hint">You may use basic HTML tags for formatting.</span>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update Article</button>
                        <a href="/posts/<%= post.id %>" class="btn btn-outline">Cancel</a>
                    </div>
                </form>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
