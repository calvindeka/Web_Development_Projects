<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Share a new devotional, testimony, or Scripture reflection.">
    <title>Write an Article | Faithful Word</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <main>
        <section class="form-section">
            <div class="container container-narrow">
                <header class="form-header">
                    <h1>Write an Article</h1>
                    <p>Share your testimony, a devotional, or a Scripture reflection to encourage others in their faith journey.</p>
                </header>

                <form action="/posts" method="POST" class="post-form">
                    <div class="form-group">
                        <label for="title">Title</label>
                        <input 
                            type="text" 
                            id="title" 
                            name="title" 
                            required 
                            placeholder="Enter a meaningful title"
                            maxlength="200"
                        >
                    </div>

                    <div class="form-group">
                        <label for="author">Author</label>
                        <input 
                            type="text" 
                            id="author" 
                            name="author" 
                            required 
                            placeholder="Your name"
                            maxlength="100"
                        >
                    </div>

                    <div class="form-group">
                        <label for="category">Category</label>
                        <select id="category" name="category" required>
                            <option value="">Select a category</option>
                            <option value="Devotional">Devotional</option>
                            <option value="Scripture Study">Scripture Study</option>
                            <option value="Prayer">Prayer</option>
                            <option value="Testimony">Testimony</option>
                            <option value="Christian Living">Christian Living</option>
                            <option value="Faith">Faith</option>
                            <option value="Grace">Grace</option>
                            <option value="Community">Community</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="excerpt">Excerpt</label>
                        <textarea 
                            id="excerpt" 
                            name="excerpt" 
                            rows="3" 
                            required
                            placeholder="A brief summary that will appear on the homepage (2-3 sentences)"
                            maxlength="300"
                        ></textarea>
                        <span class="form-hint">This will be displayed as a preview on the homepage.</span>
                    </div>

                    <div class="form-group">
                        <label for="content">Content</label>
                        <textarea 
                            id="content" 
                            name="content" 
                            rows="15" 
                            required
                            placeholder="Write your article here. You can use HTML for formatting (e.g., <p>, <strong>, <em>, <blockquote>)."
                        ></textarea>
                        <span class="form-hint">You may use basic HTML tags for formatting.</span>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Publish Article</button>
                        <a href="/" class="btn btn-outline">Cancel</a>
                    </div>
                </form>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
