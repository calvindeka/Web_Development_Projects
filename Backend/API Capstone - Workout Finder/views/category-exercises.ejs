<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= categoryName %> Exercises | Workout Finder</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="logo">
                <span class="logo-icon">💪</span>
                <span class="logo-text">Workout Finder</span>
            </a>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/muscles">Muscles</a></li>
                <li><a href="/categories" class="active">Categories</a></li>
                <li><a href="/equipment">Equipment</a></li>
                <li><a href="/random" class="nav-cta">Random Workout</a></li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content page-content">
        <div class="page-header">
            <a href="/categories" class="back-link">← Back to Categories</a>
            <h1><%= categoryName %> Exercises</h1>
            <p>Showing <%= exercises.length %> exercises for <%= categoryName %></p>
        </div>

        <% if (error) { %>
            <div class="error-message">
                <p><%= error %></p>
                <a href="/categories" class="btn btn-primary">Back to Categories</a>
            </div>
        <% } else if (exercises && exercises.length > 0) { %>
            <div class="exercises-grid">
                <% exercises.forEach(exercise => { %>
                    <a href="/exercise/<%= exercise.id %>" class="exercise-card">
                        <% if (exercise.image) { %>
                            <div class="exercise-image">
                                <img src="<%= exercise.image %>" alt="<%= exercise.name %>" loading="lazy">
                            </div>
                        <% } else { %>
                            <div class="exercise-image no-image">
                                <span>🏋️</span>
                            </div>
                        <% } %>
                        <div class="exercise-info">
                            <h3><%= exercise.name %></h3>
                            <% if (exercise.muscles && exercise.muscles.length > 0) { %>
                                <div class="exercise-muscles">
                                    <% exercise.muscles.slice(0, 3).forEach(muscle => { %>
                                        <span class="muscle-tag"><%= muscle %></span>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <div class="no-results">
                <div class="no-results-icon">🔍</div>
                <h2>No exercises found</h2>
                <p>We couldn't find any exercises for this category.</p>
                <a href="/categories" class="btn btn-primary">Browse Other Categories</a>
            </div>
        <% } %>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <p>Powered by <a href="https://wger.de/" target="_blank" rel="noopener">wger Workout Manager API</a></p>
            <p class="footer-note">Built by Calvin Deka | API Capstone Project</p>
        </div>
    </footer>
</body>
</html>
