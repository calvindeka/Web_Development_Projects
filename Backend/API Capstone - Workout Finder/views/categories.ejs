<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories | Workout Finder</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="logo">
                <span class="logo-icon">💪</span>
                <span class="logo-text">Workout Finder</span>
            </a>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/muscles">Muscles</a></li>
                <li><a href="/categories" class="active">Categories</a></li>
                <li><a href="/equipment">Equipment</a></li>
                <li><a href="/random" class="nav-cta">Random Workout</a></li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content page-content">
        <div class="page-header">
            <h1>Exercise Categories</h1>
            <p>Browse exercises by body part or workout type</p>
        </div>

        <% if (error) { %>
            <div class="error-message">
                <p><%= error %></p>
                <a href="/" class="btn btn-primary">Go Home</a>
            </div>
        <% } else if (categories && categories.length > 0) { %>
            <div class="categories-grid">
                <% categories.forEach(category => { %>
                    <a href="/category/<%= category.id %>" class="category-card">
                        <div class="category-icon">
                            <% 
                                const catIcons = {
                                    'Arms': '💪',
                                    'Legs': '🦵',
                                    'Abs': '🎯',
                                    'Chest': '🫁',
                                    'Back': '🔙',
                                    'Shoulders': '🦾',
                                    'Calves': '🦶',
                                    'Cardio': '❤️'
                                };
                                let catIcon = '🏋️';
                                Object.keys(catIcons).forEach(key => {
                                    if (category.name.toLowerCase().includes(key.toLowerCase())) {
                                        catIcon = catIcons[key];
                                    }
                                });
                            %>
                            <%= catIcon %>
                        </div>
                        <h3><%= category.name %></h3>
                    </a>
                <% }) %>
            </div>
        <% } %>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <p>Powered by <a href="https://wger.de/" target="_blank" rel="noopener">wger Workout Manager API</a></p>
            <p class="footer-note">Built by Calvin Deka | API Capstone Project</p>
        </div>
    </footer>
</body>
</html>
